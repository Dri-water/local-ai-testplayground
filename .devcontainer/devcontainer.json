// For format details, see https://aka.ms/devcontainer.json.
{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",

  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y chromium && mkdir -p ~/.local/bin && printf '%s\\n' '#!/usr/bin/env bash' 'exec /usr/bin/chromium --no-sandbox --disable-setuid-sandbox \"$@\"' > ~/.local/bin/cline-chromium && chmod +x ~/.local/bin/cline-chromium",

  "customizations": {
    "vscode": {
      "settings": {
        "cline.chromeExecutablePath": "/home/vscode/.local/bin/cline-chromium"
      }
    }
  }
}